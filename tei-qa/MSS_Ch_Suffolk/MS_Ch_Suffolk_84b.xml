               <head>Grant; Hamerlound in Bury St Edmunds; c. 1260-70</head>
               <msContents>
                  <textLang mainLang="la">Latin</textLang>
                  <msItem>
                     <p> 
                        <persName>
                           <forename>Richard</forename>, son of <persName>
                              <forename>Katherine</forename> of <surname>St. Edmund</surname></persName></persName>, 
                        grants to <persName>
                           <forename>Robert</forename>, the prior</persName>, and the
                        brethren of the <orgName key="org_105024">hospital of St. Peter</orgName> all right to 6d. annual rent 
                        which he was accustomed to take from the said brethren for one acre of arable land in
                        <placeName key="place_105324">Hamerlound</placeName>. 
                        (<origDate notBefore="1260" notAfter="1270" precision="low">c. 1260-70</origDate>.) 
                        Witn. <persName>
                           <forename>Geoffrey</forename>, alderman</persName>,
                        <persName>
                           <forename>William</forename> 
                           <surname type="patronymic">son of Bartholomew</surname>
                        </persName> and 
                        <persName>
                           <forename>William</forename> da <surname>Walepole</surname></persName>, bailiffs
                        <persName>
                           <forename>Adam</forename> de <surname>Westle</surname></persName>, etc.
                     </p>
                  </msItem>
               </msContents>
